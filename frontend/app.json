{
  "expo": {
    "name": "Tazakkur",
    "slug": "tazakkur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mosque-logo.png",
    "scheme": "tazakkur",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-logo-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tazakkur.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Tazakkur needs access to your microphone to record audio for homework assignments.",
        "NSCameraUsageDescription": "Tazakkur needs access to your camera to take photos for homework assignments.",
        "NSPhotoLibraryUsageDescription": "Tazakkur needs access to your photo library to select photos for homework assignments.",
        "NSPhotoLibraryAddUsageDescription": "Tazakkur needs permission to save photos to your library."
      }
    },
    "android": {
      "package": "com.tazakkur.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/mosque-logo.png",
        "backgroundColor": "#F8F6F2"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo-transparent.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A2E"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tazakkur needs access to your photos for homework assignments.",
          "cameraPermission": "Tazakkur needs access to your camera for homework assignments."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b0a306ed-8647-4ec0-a973-99cb3bba0466"
      }
    }
  }
}
